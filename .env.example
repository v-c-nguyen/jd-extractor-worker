# PostgreSQL (e.g. Neon). Required for /bidders CRUD API and app sign-in.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Dashboard auth (NextAuth). Generate a secret, e.g. openssl rand -base64 32
# AUTH_SECRET=

# Production site URL for auth callbacks (optional in local dev)
# AUTH_URL=https://your-domain.example

# Create first user after running db/migrations/006_app_users_and_daily_reports.sql:
#   npm run create-user  (set APP_USER_EMAIL, APP_USER_PASSWORD; optional APP_USER_NAME)
# APP_USER_EMAIL=
# APP_USER_PASSWORD=
# APP_USER_NAME=

SHEET_ID=
SHEET_TAB=
GOOGLE_APPLICATION_CREDENTIALS=
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional: after each pipeline cycle, GET this Apps Script Web App URL so team
# sheets sync runs (onEdit does not fire for API updates). Match token to Script
# property TEAM_SYNC_HOOK_TOKEN — see docs/google-apps-script-sync-saul.gs (doGet).
# TEAM_SYNC_WEBAPP_URL=https://script.google.com/macros/s/.../exec
# TEAM_SYNC_WEBAPP_TOKEN=